generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid())
  userName           String              @unique
  nickName           String?
  email              String?             @unique
  iconImageKey       String?
  ranking            Int?                @default(0)
  clearPlayCount     Int                 @default(0)
  failurePlayCount   Int                 @default(0)
  interruptPlayCount Int                 @default(0)
  playDungeonCount   Int                 @default(0)
  totalPlayTime      Int                 @default(0)
  totalPlayScore     Int                 @default(0)
  isActive           Boolean             @default(true)
  deletedFlg         Boolean             @default(false)
  lastLoginAt        DateTime?
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  role               Role                @default(USER)
  emailVerified      DateTime?
  hashedPassword     String?
  accounts           Account[]
  dungeons           Dungeon[]
  favouriteDungeons  FavouritesDungeon[]
  playHistories      PlayHistory[]
  sessions           Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dungeon {
  id                 String              @id @default(uuid())
  code               String              @unique
  userId             String
  name               String
  description        String?
  mapData            Json
  mapSizeHeight      Int
  mapSizeWidth       Int
  timeLimit          Int                 @default(60)
  difficulty         Int                 @default(1)
  status             DungeonStatus       @default(DRAFT)
  publishedAt        DateTime?
  isTemplate         Boolean             @default(false)
  clearPlayCount     Int                 @default(0)
  failurePlayCount   Int                 @default(0)
  interruptPlayCount Int                 @default(0)
  totalPlayTime      Int                 @default(0)
  totalPlayScore     Int                 @default(0)
  favouritesCount    Int                 @default(0)
  version            Int                 @default(1)
  deletedFlg         Boolean             @default(false)
  createdBy          String
  updatedBy          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  mapSize            Int
  user               User                @relation(fields: [userId], references: [id])
  dungeonTags        DungeonTag[]
  favouritedBy       FavouritesDungeon[]
  playHistories      PlayHistory[]
}

model Tag {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  createdAt   DateTime     @default(now())
  dungeonTags DungeonTag[]
}

model DungeonTag {
  id        Int     @id @default(autoincrement())
  dungeonId String
  tagId     Int
  dungeon   Dungeon @relation(fields: [dungeonId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([dungeonId, tagId])
  @@index([dungeonId])
  @@index([tagId])
}

model PlayHistory {
  id         String     @id @default(uuid())
  userId     String
  dungeonId  String
  playTime   Int        @default(0)
  playScore  Int        @default(0)
  playStatus PlayStatus
  createdAt  DateTime   @default(now())
  dungeon    Dungeon    @relation(fields: [dungeonId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([userId, dungeonId, createdAt])
  @@index([userId])
  @@index([dungeonId])
  @@index([createdAt])
}

model FavouritesDungeon {
  id        String   @id @default(uuid())
  userId    String
  dungeonId String
  createdAt DateTime @default(now())
  dungeon   Dungeon  @relation(fields: [dungeonId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, dungeonId])
  @@index([userId])
  @@index([dungeonId])
}

enum Role {
  USER
  ADMIN
}

enum DungeonStatus {
  DRAFT
  PUBLISHED
  PRIVATE
}

enum PlayStatus {
  CLEAR
  FAILURE
  INTERRUPT
}
